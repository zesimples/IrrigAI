# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://irrigai:irrigai_dev@db:5432/irrigai
DATABASE_URL_SYNC=postgresql://irrigai:irrigai_dev@db:5432/irrigai

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── App ───────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-in-production
DEBUG=false
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000

# ── LLM — OpenAI ─────────────────────────────────────────────────────────────
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# ── Data providers ────────────────────────────────────────────────────────────
# Options: mock | irriwatch | myirrigation
PROBE_PROVIDER=mock
WEATHER_PROVIDER=mock

# ── IrriWatch (Hydrosat B.V.) ─────────────────────────────────────────────────
# Find these in the IrriWatch portal:
#   - Client ID / API Key:    User Profile → API credentials
#   - Client Secret / Password: same page
#   - Company UUID:           Organization tab → Company Details
#
# After filling in client_id + client_secret, run:
#   docker compose exec backend python -m app.tools.irriwatch_discover
# to auto-discover your company_uuid and available order/field names.

IRRIWATCH_BASE_URL=https://api.irriwatch.hydrosat.com
IRRIWATCH_CLIENT_ID=
IRRIWATCH_CLIENT_SECRET=
IRRIWATCH_COMPANY_UUID=

# ── MyIrrigation ──────────────────────────────────────────────────────────────
# Obtain credentials from the MyIrrigation portal.
# Set PROBE_PROVIDER=myirrigation and/or WEATHER_PROVIDER=myirrigation to activate.
#
# Probe external_id format: "{project_id}/{device_id}"
# Run the discovery tool after configuring credentials:
#   docker compose exec backend python -m app.tools.myirrigation_discover

MYIRRIGATION_BASE_URL=http://api.myirrigation.eu/api/v1
MYIRRIGATION_USERNAME=
MYIRRIGATION_PASSWORD=
MYIRRIGATION_CLIENT_ID=
MYIRRIGATION_CLIENT_SECRET=
MYIRRIGATION_PROJECT_ID=        # numeric project ID for weather forecast endpoint
MYIRRIGATION_WEATHER_DEVICE_ID= # device ID of the iMetos/weather station for observations
