# Database
DATABASE_URL=postgresql+asyncpg://irrigai:irrigai_dev@db:5432/irrigai
DATABASE_URL_SYNC=postgresql://irrigai:irrigai_dev@db:5432/irrigai
POSTGRES_USER=irrigai
POSTGRES_PASSWORD=irrigai_dev
POSTGRES_DB=irrigai

# Redis
REDIS_URL=redis://redis:6379/0

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
SECRET_KEY=change-me-in-production
DEBUG=true
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Probe Data Provider (mock until real API is provided)
PROBE_PROVIDER=mock
PROBE_API_URL=
PROBE_API_KEY=

# Weather Data Provider (mock until real API is provided)
WEATHER_PROVIDER=mock
WEATHER_API_URL=
WEATHER_API_KEY=

# AI / LLM — OpenAI ChatGPT
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Set LLM_PROVIDER=mock to run without an API key

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# Localization
DEFAULT_LANGUAGE=pt
DEFAULT_TIMEZONE=Europe/Lisbon
